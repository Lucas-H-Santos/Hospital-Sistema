# Configurações do Servidor
PORT=5000
NODE_ENV=development

# Configurações do MongoDB
MONGO_URI=mongodb://localhost:27017/hospital_db
MONGODB_URI=mongodb://localhost:27017/hospital_db

# Configurações de JWT
JWT_SECRET=sua_chave_secreta_muito_longa_e_aleatoria_aqui
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# CORS — origem permitida do frontend
ALLOWED_ORIGIN=http://localhost:3000

# URL base do frontend (evitar Host Header Injection no reset de senha)
FRONTEND_URL=http://localhost:3000

# Configurações de Email
EMAIL_SERVICE=gmail
EMAIL_USERNAME=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_de_app
EMAIL_FROM=noreply@hospital.com
